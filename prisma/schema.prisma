generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USUARIO
  SEM_PERMISSAO
}

model Department {
  id                String   @id @default(cuid())
  name              String   @unique
  nexusDepartmentId String?  @unique @map("nexus_department_id")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  users             User[]

  @@map("departments")
}

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  passwordHash  String     @map("password_hash")
  role          UserRole   @default(SEM_PERMISSAO)
  jobTitle      String?    @map("job_title")
  birthDate     DateTime?  @map("birth_date")
  gender        String?
  active        Boolean    @default(true)
  leftAt        DateTime?  @map("left_at")
  avatarUrl     String?    @map("avatar_url")
  phone         String?
  domainAccount String?    @map("domain_account")
  windowsUser   String?    @map("windows_user")
  nexusUserId   String?    @unique @map("nexus_user_id")
  origin        String     @default("local")
  departmentId  String?    @map("department_id")
  department    Department? @relation(fields: [departmentId], references: [id])
  entryDate     DateTime?  @map("entry_date")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

// Linhas cruas da planilha de cadastro (admissão/nascimento) + vínculo.
model PersonalStaging {
  id                String   @id @default(cuid())
  nome              String
  norm              String
  birthRaw          String?  @map("birth_raw")
  admRaw            String?  @map("adm_raw")
  sexo              String?
  situacao          String?
  suggestionNexusId String?  @map("suggestion_nexus_id")
  confidence        String   @default("none")
  matchedNexusId    String?  @map("matched_nexus_id")
  status            String   @default("pending")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("personal_staging")
}

// Escolaridade REAL (vinda da planilha de RH), por funcionário.
model EmployeeEducation {
  nexusUserId String   @id @map("nexus_user_id")
  level       String?
  sexo        String?
  detail      String?
  raw         Json?
  source      String   @default("planilha")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("employee_education")
}

// Cursos/treinamentos e certificações (listas livres, editadas na ficha).
// Independente da escolaridade. Json = [{ nome: string, ano?: string }].
model EmployeeTraining {
  nexusUserId String   @id @map("nexus_user_id")
  cursos      Json     @default("[]")
  certs       Json     @default("[]")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("employee_training")
}

// Linhas cruas da planilha + estado do vínculo (alimenta a tela de vínculo).
model EducationStaging {
  id                String   @id @default(cuid())
  nome              String
  norm              String
  level             String?
  sexo              String?
  detail            String?
  raw               Json?
  suggestionNexusId String?  @map("suggestion_nexus_id")
  confidence        String   @default("none")
  matchedNexusId    String?  @map("matched_nexus_id")
  status            String   @default("pending")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("education_staging")
}

model ClassroomStat {
  nexusUserId      String   @id @map("nexus_user_id")
  videosCompleted  Int      @default(0) @map("videos_completed")
  coursesCompleted Int      @default(0) @map("courses_completed")
  coursesCreated   Int      @default(0) @map("courses_created")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("classroom_stats")
}

model RadioStat {
  nexusUserId    String    @id @map("nexus_user_id")
  totalSeconds   Int       @default(0) @map("total_seconds")
  sessions       Int       @default(0)
  lastListenedAt DateTime? @map("last_listened_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("radio_stats")
}

// Espelho diário do uso da rádio (por usuário × dia) — base dos filtros de
// período. day = data local (America/Sao_Paulo) vinda do .68. Upsert SET por dia
// torna o sync incremental idempotente.
model RadioDaily {
  nexusUserId String   @map("nexus_user_id")
  day         String   @db.VarChar(10) // YYYY-MM-DD
  seconds     Int      @default(0)
  sessions    Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@id([nexusUserId, day])
  @@index([day])
  @@map("radio_daily")
}

// Espelho diário do WhatsApp/OneCode (por departamento × dia). abertos = chamados
// criados no dia. color = cor da fila/depto (denormalizada). Mesmo modelo da rádio.
model WhatsappDaily {
  dept      String
  day       String   @db.VarChar(10) // YYYY-MM-DD
  abertos   Int      @default(0)
  color     String?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([dept, day])
  @@index([day])
  @@map("whatsapp_daily")
}

// Marcador de última sincronização por fonte (sync incremental).
model SyncWatermark {
  source       String   @id
  lastSyncedAt DateTime @map("last_synced_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("sync_watermark")
}
